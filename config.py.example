KDP_FONT = "Garamond"

from dataclasses import dataclass, field
from typing import List

@dataclass
class BookConfig:
    title: str
    genre: str
    target_words: int
    chapters: int
    topic: str = ""
    writing_style: str = "Professional, concise, and engaging"
    tone: str = "professional"
    target_audience: str = "general audience"
    niche_keywords: List[str] = field(default_factory=list)
    language: str = "english"
    author_name: str = "AI Publishing House"
    description: str = ""

PROFITABLE_NICHES = [
